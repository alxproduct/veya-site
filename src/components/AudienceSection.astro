---
interface Props {
  id: string;
  eyebrow: string;
  headline: string;
  lead: string;
  image: { src: string; alt: string };
  surfaceVar: string;
  textColorVar: string;
  /* Per-section accent bar colour for the point items */
  accentBarVar?: string;
  points: ReadonlyArray<{ title: string; body: string }>;
  cta: { label: string; href: string };
}

const {
  id, eyebrow, headline, lead, image,
  surfaceVar, textColorVar,
  accentBarVar = '--teal-500',
  points, cta
} = Astro.props;
---

<section id={id} class="audience section" aria-labelledby={`${id}-heading`}>
  <div class="container">
    <div class="two-col audience__header">
      <p class="eyebrow audience__eyebrow">{eyebrow}</p>
      <div class="audience__intro">
        <h2 id={`${id}-heading`} class="audience__headline" set:html={headline} />
        <p class="audience__lead">{lead}</p>
        <div
          class="audience__image"
          style={`background: var(${surfaceVar});`}
        >
          <img src={image.src} alt={image.alt} loading="lazy" />
        </div>
      </div>
    </div>

    <ul class="audience__points" role="list">
      {
        points.map((point) => (
          <li class="audience-point">
            <span
              class="audience-point__bar"
              style={`background: var(${accentBarVar});`}
              aria-hidden="true"
            />
            <h3 class="audience-point__title">{point.title}</h3>
            <p class="audience-point__body">{point.body}</p>
          </li>
        ))
      }
    </ul>

    <div class="audience__cta-wrap">
      <a href={cta.href} class="btn btn--primary">
        <span>{cta.label}</span>
        <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .audience__header {
    margin-bottom: var(--space-7);
    align-items: start;
  }

  /* Eyebrow nudge calibrated for display-56 cap-line */
  .audience__eyebrow {
    padding-top: 6px;
  }

  .audience__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Signifier Bold 56 / 105% / -2% per spec */
  .audience__headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-display-56);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
    max-width: 16ch;
  }

  /* Signifier Regular 18 */
  .audience__lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body-large);
    line-height: 1.5;
    color: var(--text-secondary);
    max-width: 60ch;
  }

  .audience__image {
    margin-top: var(--space-5);
    aspect-ratio: 16 / 12;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .audience__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .audience__points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-7);
  }

  .audience-point {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .audience-point__bar {
    display: block;
    width: 24px;
    height: 3px;
    border-radius: var(--radius-xs);
  }

  .audience-point__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    color: var(--text-primary);
    margin-top: var(--space-2);
  }

  .audience-point__body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .audience__cta-wrap {
    margin-top: var(--space-5);
  }

  @media (max-width: 1024px) {
    .audience__eyebrow {
      padding-top: 0;
    }
    .audience__points {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
