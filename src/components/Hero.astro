---
import { hero } from '~/data/landing';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="eyebrow eyebrow--dotted hero__eyebrow">{hero.eyebrow}</p>

      <h1 id="hero-heading" class="hero__headline" set:html={hero.headline} />

      <p class="hero__lead">{hero.subheadline}</p>

      <div class="hero__ctas">
        {
          hero.ctas.map((cta) => (
            <a
              href={cta.href}
              class:list={[
                'btn',
                cta.variant === 'primary' ? 'btn--primary' : 'btn--secondary',
              ]}
              target={cta.href.startsWith('http') ? '_blank' : undefined}
              rel={cta.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <span>{cta.label}</span>
              {cta.arrow && <span class="btn__arrow" aria-hidden="true">→</span>}
            </a>
          ))
        }
      </div>

      <ul class="hero__trust" aria-label="Trust signals">
        {
          hero.trustStrip.map((item) => (
            <li class="hero__trust-item">
              <span class="hero__trust-dash" aria-hidden="true">{item.dash}</span>
              <span>{item.label}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="hero__image-card" aria-hidden="true">
      <span class="hero__card-label hero__card-label--top">{hero.imageCard.topLabel}</span>
      <div class="hero__image-slot">
        <img src={hero.imageCard.src} alt={hero.imageCard.alt} loading="eager" fetchpriority="high" />
      </div>
      <div class="hero__card-footer">
        <span class="hero__card-label">{hero.imageCard.bottomLeft}</span>
        <span class="hero__card-label">{hero.imageCard.bottomRight}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-7) var(--space-9);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    /* Content height matches image height — no overshoot below */
    align-items: stretch;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    /* Distribute content vertically within the row height */
    justify-content: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-1);
  }

  /* Hero headline: Signifier Bold 108 with -3px letter-spacing. */
  .hero__headline {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: var(--tracking-hero);
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  /* Hero lead: Signifier Regular 16 */
  .hero__lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--text-secondary);
    max-width: 60ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  /* Trust strip — single line */
  .hero__trust {
    list-style: none;
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-4);
    margin-top: var(--space-3);
    padding: 0;
    align-items: center;
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .hero__trust-dash {
    color: var(--text-muted);
  }

  /* ----- Image card -----
     Background: primitives/paper/50 per Figma.
     18px bottom padding (per spec, was 24px). */
  .hero__image-card {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--paper-50);
    padding: 24px 24px 18px 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--ink-950);
  }

  .hero__image-slot {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__card-label {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-700);
    z-index: 1;
  }

  /* "A PRIVATE NETWORK" — brand purple */
  .hero__card-label--top {
    align-self: flex-end;
    color: var(--violet-500);
  }

  .hero__card-footer {
    display: flex;
    justify-content: space-between;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .hero {
      padding-block: var(--space-6) var(--space-7);
    }

    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-7);
      align-items: start;
    }

    .hero__image-card {
      aspect-ratio: 1 / 1;
      max-width: 480px;
      margin-inline: auto;
      width: 100%;
    }

    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__trust {
      flex-wrap: wrap;
      gap: var(--space-2);
    }
  }
</style>
