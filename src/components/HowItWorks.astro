---
import { howItWorks } from '~/data/landing';
import SectionHeader from '~/components/SectionHeader.astro';
---

<section id="how-it-works" class="how section" aria-labelledby="how-heading">
  <div class="container">
    <SectionHeader
      eyebrow={howItWorks.eyebrow}
      headline={howItWorks.headline}
      id="how-heading"
      size="display-64"
    />

    <p class="how__lead">{howItWorks.lead}</p>

    <ol class="how__grid" role="list">
      {
        howItWorks.steps.map((step) => (
          <li class="how-step">
            <img src={step.numberSvg} alt={step.number} class="how-step__num" />
            <span class="how-step__rule" aria-hidden="true" />
            <h3 class="how-step__title">{step.title}</h3>
            <p class="how-step__body">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how__lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body-large);
    line-height: 1.5;
    color: var(--text-secondary);
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  .how__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    list-style: none;
    padding: 0;
  }

  .how-step {
    padding: var(--space-6);
    background: var(--surface-soft);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 280px;
    align-items: flex-start;  /* SVG numbers and rule left-aligned */
  }

  .how-step__num {
    height: 36px;
    width: auto;
    margin-bottom: var(--space-4);
    display: block;
  }

  .how-step__rule {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--violet-500);
    border-radius: var(--radius-xs);
    margin-bottom: var(--space-2);
  }

  .how-step__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-step-title);
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0;
  }

  .how-step__body {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: var(--text-small);
    line-height: 1.5;
    color: var(--text-secondary);
  }

  @media (max-width: 1280px) {
    .how__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .how__grid {
      grid-template-columns: 1fr;
    }
    .how-step {
      min-height: auto;
    }
  }
</style>
