---
import { manifesto } from '~/data/landing';
---

<section id="manifesto" class="manifesto section" aria-labelledby="manifesto-heading">
  <div class="container">
    <div class="two-col manifesto__inner">
      <p class="eyebrow manifesto__eyebrow">{manifesto.eyebrow}</p>
      <div class="manifesto__content">
        <h2 id="manifesto-heading" class="manifesto__headline" set:html={manifesto.headline} />
        <p class="manifesto__body">{manifesto.body}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .manifesto__inner {
    padding-block: var(--space-6);
    align-items: start;
  }

  .manifesto__eyebrow {
    padding-top: 14px;  /* aligned with display-84 cap-line */
  }

  .manifesto__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 920px;
  }

  /* Signifier Bold 84 / 88 line-height / -2px tracking */
  .manifesto__headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-display-84);
    line-height: calc(88 / 84);
    letter-spacing: -0.024em;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .manifesto__body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body-large);
    line-height: 1.5;
    color: var(--text-secondary);
    max-width: 64ch;
  }

  @media (max-width: 1024px) {
    .manifesto__eyebrow {
      padding-top: 0;
    }
  }
</style>
