---
import { commitments } from '~/data/landing';
import SectionHeader from '~/components/SectionHeader.astro';
---

<section id="commitments" class="commitments section" aria-labelledby="commitments-heading">
  <div class="container">
    <SectionHeader
      eyebrow={commitments.eyebrow}
      headline={commitments.headline}
      id="commitments-heading"
      size="display-72"
    />

    <ul class="commitments__grid" role="list">
      {
        commitments.cards.map((card) => (
          <li class="commitment-card">
            <div
              class="commitment-card__media"
              style={`background: var(${card.surfaceVar});`}
            >
              <img src={card.image.src} alt={card.image.alt} loading="lazy" />
            </div>
            <div class="commitment-card__body">
              <p class="commitment-card__label">{card.label}</p>
              <h3 class="commitment-card__title" set:html={card.title} />
              <p class="commitment-card__copy">{card.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .commitments__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    list-style: none;
    padding: 0;
  }

  /* Card body = dark gray (surface-soft) on the dark canvas.
     White text throughout. */
  .commitment-card {
    display: flex;
    flex-direction: column;
    background: var(--surface-soft);
    color: var(--paper-50);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  /* Image area: fixed 460px height, full card width,
     per-card coloured background, image inside. */
  .commitment-card__media {
    height: 460px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .commitment-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .commitment-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .commitment-card__label {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--paper-50);
    opacity: 0.7;
  }

  /* Card title: Signifier Bold 32 / line-height 36 / -0.5px tracking */
  .commitment-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-card-title);
    line-height: calc(36 / 32);
    letter-spacing: -0.015em;
    color: var(--paper-50);
    margin: 0;
  }

  /* Card body: Signifier Regular 16 */
  .commitment-card__copy {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--paper-50);
    opacity: 0.85;
  }

  @media (max-width: 1024px) {
    .commitments__grid {
      grid-template-columns: 1fr;
    }
    .commitment-card__media {
      height: 320px;
    }
  }
</style>
